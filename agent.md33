                ))}
              </div>
            </div>

            <div>
              <ul className="space-y-6">
                {['About Us', 'Contact Us', 'Bookings', 'Blogs', 'Services'].map((item) => (
                  <li key={item}>
                    <button className="text-black text-lg font-medium font-['Geist'] leading-5 tracking-tight hover:text-stone-600 transition-colors duration-200">
