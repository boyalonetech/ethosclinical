  BookOpen,
  Heart,
  Shield,
  Users
} from 'lucide-react';

const HomePage: React.FC = () => {
  return (
    <div className="w-full min-h-screen bg-white overflow-x-hidden">
      {/* Main Content */}
      <div className="bg-stone-50 overflow-hidden">
        {/* Navigation */}
        <nav className="w-full px-16 py-5 bg-stone-50 flex justify-between items-center sticky top-0 z-50">
          <div className="relative w-36 h-14">
            <Image
              src="https://placehold.co/140x58"
              alt="Logo"
              fill
              className="object-contain"
            />
          </div>
          
          <div className="w-[860px] flex justify-between items-center">
            <div className="flex justify-start items-center gap-12">
              {['Home', 'About', 'Contact', 'Blog'].map((item, index) => (
                <button
                  key={item}
