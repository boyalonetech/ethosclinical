            <div className="absolute bottom-[72px] left-[50px] w-5 h-5 bg-white rounded-full" />
            <div className="absolute bottom-[72px] left-[92px] w-5 h-5 bg-white rounded-full" />
            <div className="absolute bottom-[119px] left-[92px] w-5 h-5 bg-white rounded-full" />
          </div>
          
          <div className="text-center relative z-10">
            <h2 className="text-white text-3xl font-normal font-['Bona_Nova'] leading-10 tracking-tight mb-6">
              Ethos Clinical Supervision
            </h2>
            <p className="text-stone-50 text-4xl font-normal font-['Geist'] leading-10 max-w-[891px] mx-auto mb-8">
              An organisation built on a strong commitment to supporting people.
            </p>
            <button className="px-5 py-3.5 bg-stone-500 rounded-[5px] hover:bg-stone-600 transition-colors duration-200 inline-flex items-center gap-2">
              <BookOpen className="w-5 h-5 text-white" />
              <span className="text-white text-lg font-medium font-['Geist'] leading-5 tracking-tight">
                Book a Counsellor
              </span>
            </button>
          </div>
        </div>
      </div>

      {/* Footer */}
      <footer className="w-full bg-yellow-50 py-[70px]">
        <div className="max-w-[1440px] mx-auto px-[70px]">
          <div className="flex flex-wrap justify-between gap-12">
            <div className="max-w-[384px]">
              <div className="relative w-32 h-14 mb-8">
                <Image
                  src="https://placehold.co/135x56"
                  alt="Logo"
